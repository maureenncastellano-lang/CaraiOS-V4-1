# Copy this file to .env and fill in real values before running.

AUTH_ENABLED=true
ADMIN_USER=admin
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-real-password

# Pin this to a real random value. A regenerated default on every restart
# silently invalidates every session (found and documented in record.md
# Session 6) — this is the single most common first-run gotcha.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Your Ollama instance (or any OpenAI/Ollama-compatible endpoint)
OLLAMA_HOST=https://ollama.carai.agency

# Any of these you actually have keys for — all optional, gated
# independently (see brain/llm.py's available_providers).
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# Optional: web search for Workers with the search_web tool (most of them)
TAVILY_API_KEY=

# Optional: only needed if you want the Supabase/pgvector memory backend
# instead of the default SQLite (see memory/store.py) — untested in this
# project; SQLite is the only backend with real test coverage so far.
# SUPABASE_URL=
# SUPABASE_KEY=
