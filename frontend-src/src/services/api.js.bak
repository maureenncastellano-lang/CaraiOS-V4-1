const BASE = process.env.REACT_APP_BACKEND_URL || "http://localhost:3001";

async function getToken() {
  // Try Supabase session first, fallback to null (dev mode)
  try {
    const { supabase } = await import("../services/supabase");
    const { data: { session } } = await supabase.auth.getSession();
    return session?.access_token || null;
  } catch { return null; }
}

async function req(path, opts = {}) {
  const token = await getToken();
  const r = await fetch(`${BASE}${path}`, {
    ...opts,
    headers: {
      "Content-Type": "application/json",
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
      ...(opts.headers || {}),
    },
  });
  if (!r.ok) {
    const err = await r.json().catch(() => ({ error: r.statusText }));
    throw new Error(err.error || err.message || `HTTP ${r.status}`);
  }
  return r.json();
}

async function* parseSSE(response) {
  const reader = response.body.getReader();
  const decoder = new TextDecoder();
  let buffer = "";
  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    buffer += decoder.decode(value, { stream: true });
    const lines = buffer.split("\n");
    buffer = lines.pop();
    for (const line of lines) {
      if (!line.startsWith("data: ")) continue;
      const raw = line.slice(6).trim();
      if (raw === "[DONE]") return;
      try { yield JSON.parse(raw); } catch {}
    }
  }
}

async function sseReq(path, body) {
  const token = await getToken();
  const r = await fetch(`${BASE}${path}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
    },
    body: JSON.stringify(body),
  });
  return parseSSE(r);
}

export const api = {
  // ── Health ────────────────────────────────────────────────
  health: () => req("/api/health"),

  // ── Files ─────────────────────────────────────────────────
  getTree:    () => req("/api/files/tree"),
  readFile:   (path) => req(`/api/files/read?path=${encodeURIComponent(path)}`),
  writeFile:  (path, content) => req("/api/files/write", { method: "POST", body: JSON.stringify({ path, content }) }),
  createFile: (path, type = "file") => req("/api/files/create", { method: "POST", body: JSON.stringify({ path, type }) }),
  renameFile: (oldPath, newPath) => req("/api/files/rename", { method: "POST", body: JSON.stringify({ oldPath, newPath }) }),
  deleteFile: (path) => req("/api/files/delete", { method: "DELETE", body: JSON.stringify({ path }) }),
  downloadUrl: (path) => `${BASE}/api/files/download?path=${encodeURIComponent(path)}`,

  // ── AI ────────────────────────────────────────────────────
  getProviders: () => req("/api/ai/providers"),
  async *streamChat({ providerId, model, messages, system, activeFile, mentionedFiles, useCodebaseContext }) {
    let extraSystem = system || "";
    if (mentionedFiles?.length) {
      const pinned = mentionedFiles.map(f => `### @${f.path}\n\`\`\`\n${(f.content || "").slice(0, 3000)}\n\`\`\``).join("\n\n");
      extraSystem += `\n\n## Pinned files (@mentions)\n${pinned}`;
    }
    yield* await sseReq("/api/ai/chat", { providerId, model, messages, system: extraSystem || undefined, activeFile, useCodebaseContext });
  },
  complete: ({ providerId, model, prefix, suffix, language, filepath }) =>
    req("/api/ai/complete", { method: "POST", body: JSON.stringify({ providerId, model, prefix, suffix, language, filepath }) }),
  async *streamEdit({ providerId, model, instruction, selectedCode, fullFile, language }) {
    yield* await sseReq("/api/ai/edit", { providerId, model, instruction, selectedCode, fullFile, language });
  },
  async *streamExplain({ providerId, model, code, language }) {
    yield* await sseReq("/api/ai/explain", { providerId, model, code, language });
  },

  // ── Agent ─────────────────────────────────────────────────
  getIndexStatus: () => req("/api/agent/index/status"),
  reindex: () => req("/api/agent/index", { method: "POST" }),
  searchFiles: (query, topK = 20) => req("/api/agent/search", { method: "POST", body: JSON.stringify({ query, topK }) }),
  async *streamAgent({ providerId, model, task }) {
    yield* await sseReq("/api/agent/run", { providerId, model, task });
  },

  // ── Composer ──────────────────────────────────────────────
  composerPlan: (body) => req("/api/composer/plan", { method: "POST", body: JSON.stringify(body) }),
  async *streamComposerExecute(body) {
    yield* await sseReq("/api/composer/execute", body);
  },
  composerApply: (changes) => req("/api/composer/apply", { method: "POST", body: JSON.stringify({ changes }) }),

  // ── Flow ──────────────────────────────────────────────────
  flowScripts: () => req("/api/flow/scripts"),
  flowStats:   () => req("/api/flow/stats"),

  // ── Git ───────────────────────────────────────────────────
  gitStatus:   () => req("/api/git/status"),
  gitInit:     () => req("/api/git/init", { method: "POST" }),
  gitStage:    (files) => req("/api/git/stage", { method: "POST", body: JSON.stringify({ files }) }),
  gitUnstage:  (files) => req("/api/git/unstage", { method: "POST", body: JSON.stringify({ files }) }),
  gitCommit:   (message) => req("/api/git/commit", { method: "POST", body: JSON.stringify({ message }) }),
  gitPush:     (remote, branch) => req("/api/git/push", { method: "POST", body: JSON.stringify({ remote, branch }) }),
  gitPull:     (remote, branch) => req("/api/git/pull", { method: "POST", body: JSON.stringify({ remote, branch }) }),
  gitCheckout: (branch, create) => req("/api/git/checkout", { method: "POST", body: JSON.stringify({ branch, create }) }),
  gitDiscard:  (path) => req("/api/git/discard", { method: "POST", body: JSON.stringify({ path }) }),
  gitDiff:     (path) => req(`/api/git/diff${path ? "?path=" + encodeURIComponent(path) : ""}`),

  // ── Settings ──────────────────────────────────────────────
  getSettings:  () => req("/api/settings"),
  saveSettings: (s) => req("/api/settings", { method: "PUT", body: JSON.stringify(s) }),
  patchSettings:(s) => req("/api/settings", { method: "PATCH", body: JSON.stringify(s) }),

  // ── UCIP ──────────────────────────────────────────────────
  ucipHealth:   () => req("/api/ucip/health"),
  ucipTraces:   (p = {}) => req(`/api/ucip/traces?${new URLSearchParams(p)}`),
  ucipCapabilities: () => req("/api/ucip/capabilities"),

  // ── Extensions ────────────────────────────────────────────
  searchExtensions:   (q, cat, size = 20) => req(`/api/extensions/search?q=${encodeURIComponent(q)}&category=${cat || ""}&size=${size}`),
  featuredExtensions: () => req("/api/extensions/featured"),
  extensionDetails:   (ns, name) => req(`/api/extensions/${ns}/${name}`),
};

export function getLanguageFromPath(filePath) {
  const ext = filePath?.split(".").pop()?.toLowerCase();
  const map = {
    js:"javascript", jsx:"javascript", ts:"typescript", tsx:"typescript",
    py:"python", rb:"ruby", go:"go", rs:"rust", java:"java",
    cpp:"cpp", c:"c", cs:"csharp", php:"php", swift:"swift", kt:"kotlin",
    html:"html", css:"css", scss:"scss", less:"less",
    json:"json", yaml:"yaml", yml:"yaml", toml:"toml", md:"markdown",
    xml:"xml", sql:"sql", sh:"shell", bash:"shell", dockerfile:"dockerfile",
    tf:"terraform", env:"plaintext", txt:"plaintext",
  };
  return map[ext] || "plaintext";
}
