import React, { useState, useEffect, useRef, useCallback } from "react";
import {
  Play, Square, Plus, Trash2, Clock, Key, RefreshCw,
  ChevronRight, ChevronDown, X, Save, Package, Webhook,
  CheckCircle, XCircle, Loader, Bell, Code
} from "lucide-react";

const BASE = process.env.REACT_APP_BACKEND_URL || "http://localhost:3001";

async function flowFetch(path, opts = {}) {
  const r = await fetch(`${BASE}/api/flow${path}`, {
    headers: { "Content-Type": "application/json" },
    ...opts,
  });
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}

// ── Script Editor ────────────────────────────────────────────
function ScriptEditor({ script, onSave, onClose }) {
  const [name, setName]         = useState(script?.name || "");
  const [code, setCode]         = useState(script?.code || "# Write your Python script here\nprint('Hello from DevOS Flow!')");
  const [description, setDesc]  = useState(script?.description || "");
  const [packages, setPkgs]     = useState(script?.packages?.join(", ") || "");
  const [schedule, setSched]    = useState(script?.schedule || "");
  const [schedType, setSchedType] = useState(script?.schedule_type || "manual");
  const [saving, setSaving]     = useState(false);

  const save = async () => {
    if (!name.trim()) return;
    setSaving(true);
    try {
      const body = {
        name: name.trim(), description, code,
        packages: packages.split(",").map(p => p.trim()).filter(Boolean),
        schedule: schedType === "manual" ? null : schedule,
        scheduleType: schedType,
      };
      if (script?.id) await flowFetch(`/scripts/${script.id}`, { method: "PATCH", body: JSON.stringify(body) });
      else await flowFetch("/scripts", { method: "POST", body: JSON.stringify(body) });
      onSave();
    } catch (e) { alert(e.message); }
    finally { setSaving(false); }
  };

  return (
    <div className="flow-editor">
      <div className="flow-editor-header">
        <input className="flow-editor-name" value={name} onChange={e => setName(e.target.value)} placeholder="Script name" />
        <div className="flow-editor-actions">
          <button className="btn-primary" onClick={save} disabled={saving || !name.trim()}>
            {saving ? <Loader size={13} className="spin-slow" /> : <Save size={13} />} Save
          </button>
          <button className="btn-icon" onClick={onClose}><X size={14} /></button>
        </div>
      </div>

      <div className="flow-editor-body">
        <textarea className="flow-code-area" value={code} onChange={e => setCode(e.target.value)} spellCheck={false} />

        <div className="flow-editor-meta">
          <label className="flow-meta-row">
            <span>Description</span>
            <input value={description} onChange={e => setDesc(e.target.value)} placeholder="Optional description" />
          </label>
          <label className="flow-meta-row">
            <span><Package size={12} /> Packages</span>
            <input value={packages} onChange={e => setPkgs(e.target.value)} placeholder="requests, pandas, numpy" />
          </label>
          <label className="flow-meta-row">
            <span><Clock size={12} /> Schedule</span>
            <select value={schedType} onChange={e => setSchedType(e.target.value)}>
              <option value="manual">Manual only</option>
              <option value="interval">Interval</option>
              <option value="cron">Cron</option>
            </select>
          </label>
          {schedType === "interval" && (
            <label className="flow-meta-row">
              <span>Interval</span>
              <input value={schedule} onChange={e => setSched(e.target.value)} placeholder="30m or 2h" />
            </label>
          )}
          {schedType === "cron" && (
            <label className="flow-meta-row">
              <span>Cron expr</span>
              <input value={schedule} onChange={e => setSched(e.target.value)} placeholder="0 9 * * 1-5" />
            </label>
          )}
        </div>
      </div>
    </div>
  );
}

// ── Run output viewer ────────────────────────────────────────
function RunOutput({ scriptId, onClose }) {
  const [output, setOutput] = useState([]);
  const [running, setRunning] = useState(true);
  const [status, setStatus] = useState(null);
  const bottomRef = useRef(null);
  const abortRef = useRef(null);

  useEffect(() => {
    const ctrl = new AbortController();
    abortRef.current = ctrl;
    setOutput([]); setRunning(true); setStatus(null);

    fetch(`${BASE}/api/flow/scripts/${scriptId}/run`, {
      method: "POST",
      signal: ctrl.signal,
    }).then(async res => {
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = "";
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const lines = buf.split("\n");
        buf = lines.pop();
        for (const line of lines) {
          if (!line.startsWith("data: ")) continue;
          try {
            const event = JSON.parse(line.slice(6));
            if (event.type === "output") setOutput(o => [...o, event]);
            if (event.type === "complete") { setStatus(event.status); setRunning(false); }
            if (event.type === "error") { setOutput(o => [...o, { outputType: "stderr", text: event.message }]); setRunning(false); }
          } catch {}
        }
      }
    }).catch(() => setRunning(false));

    return () => ctrl.abort();
  }, [scriptId]);

  useEffect(() => { bottomRef.current?.scrollIntoView({ behavior: "smooth" }); }, [output]);

  return (
    <div className="run-output">
      <div className="run-output-header">
        <span>
          {running ? <><Loader size={12} className="spin-slow" /> Running…</> : status === "success" ? <><CheckCircle size={12} color="#3fb950" /> Success</> : <><XCircle size={12} color="#f85149" /> Failed</>}
        </span>
        <div>
          {running && <button className="btn-stop" onClick={() => abortRef.current?.abort()}><Square size={11} /> Stop</button>}
          <button className="btn-icon" onClick={onClose}><X size={13} /></button>
        </div>
      </div>
      <div className="run-output-body">
        {output.map((o, i) => (
          <div key={i} className={`run-line ${o.outputType === "stderr" ? "stderr" : "stdout"}`}>
            <pre>{o.text}</pre>
          </div>
        ))}
        <div ref={bottomRef} />
      </div>
    </div>
  );
}

// ── Secret Manager ───────────────────────────────────────────
function SecretsPanel({ onClose }) {
  const [secrets, setSecrets] = useState([]);
  const [name, setName] = useState("");
  const [value, setValue] = useState("");
  const [desc, setDesc] = useState("");
  const [adding, setAdding] = useState(false);

  const load = () => flowFetch("/secrets").then(d => setSecrets(d.secrets || []));
  useEffect(() => { load(); }, []);

  const add = async () => {
    if (!name.trim() || !value.trim()) return;
    setAdding(true);
    try {
      await flowFetch("/secrets", { method: "POST", body: JSON.stringify({ name: name.trim(), value, description: desc }) });
      setName(""); setValue(""); setDesc("");
      load();
    } catch (e) { alert(e.message); }
    finally { setAdding(false); }
  };

  const del = async (id) => {
    if (!window.confirm("Delete this secret?")) return;
    await flowFetch(`/secrets/${id}`, { method: "DELETE" });
    load();
  };

  return (
    <div className="secrets-panel">
      <div className="secrets-header">
        <Key size={14} /> <span>Secrets</span>
        <button className="btn-icon" onClick={onClose}><X size={13} /></button>
      </div>
      <p className="secrets-hint">Secrets are encrypted and injected as environment variables. Access with <code>os.environ.get('NAME')</code></p>
      <div className="secrets-add">
        <input placeholder="NAME" value={name} onChange={e => setName(e.target.value)} className="secrets-input" />
        <input placeholder="value" type="password" value={value} onChange={e => setValue(e.target.value)} className="secrets-input" />
        <input placeholder="description (opt)" value={desc} onChange={e => setDesc(e.target.value)} className="secrets-input" />
        <button className="btn-primary" onClick={add} disabled={adding || !name || !value}>
          {adding ? <Loader size={12} /> : <Plus size={12} />} Add
        </button>
      </div>
      <div className="secrets-list">
        {secrets.map(s => (
          <div key={s.id} className="secret-row">
            <span className="secret-name">{s.name}</span>
            <span className="secret-desc">{s.description}</span>
            <button className="btn-danger-icon" onClick={() => del(s.id)}><Trash2 size={11} /></button>
          </div>
        ))}
        {secrets.length === 0 && <p className="secrets-empty">No secrets yet.</p>}
      </div>
    </div>
  );
}

// ── Main Flow Panel ──────────────────────────────────────────
export default function FlowPanel() {
  const [scripts, setScripts]   = useState([]);
  const [stats, setStats]       = useState(null);
  const [editing, setEditing]   = useState(null); // null | "new" | script object
  const [running, setRunning]   = useState(null); // script id
  const [showSecrets, setShowSecrets] = useState(false);
  const [activeTab, setActiveTab] = useState("scripts"); // scripts | secrets
  const [expanded, setExpanded] = useState(null); // expanded script id for runs history
  const [runs, setRuns]         = useState({});

  const load = useCallback(async () => {
    const [s, st] = await Promise.all([
      flowFetch("/scripts").then(d => d.scripts || []),
      flowFetch("/stats"),
    ]);
    setScripts(s);
    setStats(st);
  }, []);

  useEffect(() => { load(); }, [load]);

  const del = async (id) => {
    if (!window.confirm("Delete this script?")) return;
    await flowFetch(`/scripts/${id}`, { method: "DELETE" });
    load();
  };

  const loadRuns = async (id) => {
    const data = await flowFetch(`/scripts/${id}/runs?limit=10`);
    setRuns(r => ({ ...r, [id]: data.runs || [] }));
  };

  const toggleExpand = (id) => {
    if (expanded === id) { setExpanded(null); return; }
    setExpanded(id);
    loadRuns(id);
  };

  if (editing) return (
    <ScriptEditor
      script={editing === "new" ? null : editing}
      onSave={() => { setEditing(null); load(); }}
      onClose={() => setEditing(null)}
    />
  );

  if (running) return (
    <RunOutput scriptId={running} onClose={() => { setRunning(null); load(); }} />
  );

  if (showSecrets) return <SecretsPanel onClose={() => setShowSecrets(false)} />;

  return (
    <div className="flow-panel">
      <div className="flow-header">
        <div className="flow-header-left">
          <span className="flow-logo">🔥 DevOS Flow</span>
          {stats && <span className="flow-stats">{stats.totalScripts} scripts · {stats.totalRuns} runs</span>}
        </div>
        <div className="flow-header-right">
          <button className="btn-icon" title="Secrets" onClick={() => setShowSecrets(true)}><Key size={14} /></button>
          <button className="btn-icon" title="Refresh" onClick={load}><RefreshCw size={14} /></button>
          <button className="btn-primary" onClick={() => setEditing("new")}><Plus size={13} /> New Script</button>
        </div>
      </div>

      <div className="flow-scripts">
        {scripts.length === 0 && (
          <div className="flow-empty">
            <Code size={32} color="#8b949e" />
            <p>No scripts yet</p>
            <p className="flow-empty-hint">Create a script to automate Python tasks, schedule jobs, and manage secrets.</p>
            <button className="btn-primary" onClick={() => setEditing("new")}><Plus size={13} /> Create your first script</button>
          </div>
        )}

        {scripts.map(s => (
          <div key={s.id} className="flow-script-card">
            <div className="flow-script-main">
              <div className="flow-script-info">
                <span className="flow-script-name">{s.name}</span>
                <span className={`flow-script-status ${s.status}`}>{s.status}</span>
                {s.schedule_type !== "manual" && s.schedule && (
                  <span className="flow-script-schedule"><Clock size={10} /> {s.schedule}</span>
                )}
              </div>
              {s.description && <p className="flow-script-desc">{s.description}</p>}
              <div className="flow-script-actions">
                <button className="btn-run" onClick={() => setRunning(s.id)} disabled={s.status === "running"}>
                  {s.status === "running" ? <Loader size={12} className="spin-slow" /> : <Play size={12} />} Run
                </button>
                <button className="btn-secondary-sm" onClick={() => setEditing(s)}>Edit</button>
                <button className="btn-secondary-sm" onClick={() => toggleExpand(s.id)}>
                  {expanded === s.id ? <ChevronDown size={11} /> : <ChevronRight size={11} />} History
                </button>
                <button className="btn-danger-sm" onClick={() => del(s.id)}><Trash2 size={11} /></button>
              </div>
            </div>

            {expanded === s.id && (
              <div className="flow-runs">
                {!runs[s.id] && <Loader size={12} className="spin-slow" />}
                {runs[s.id]?.length === 0 && <p className="flow-no-runs">No runs yet</p>}
                {runs[s.id]?.map(run => (
                  <div key={run.id} className={`flow-run-row ${run.status}`}>
                    <span className="flow-run-status">
                      {run.status === "success" ? <CheckCircle size={11} color="#3fb950" /> : run.status === "running" ? <Loader size={11} className="spin-slow" /> : <XCircle size={11} color="#f85149" />}
                    </span>
                    <span className="flow-run-trigger">{run.trigger}</span>
                    <span className="flow-run-time">{new Date(run.started_at).toLocaleString()}</span>
                    {run.duration_ms && <span className="flow-run-dur">{run.duration_ms}ms</span>}
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}
